<div id="tool-wbinstaller-app" class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 col-xl-8">
            {{{form}}}
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <div class="btn-toolbar gap-2">
                <button type="button" class="btn btn-secondary" data-action="check-recipe">
                    {{#str}} analyserecipe, tool_wbinstaller {{/str}}
                </button>
                <button type="button" class="btn btn-primary" data-action="install-recipe" disabled>
                    {{#str}} vueinstallbtn, tool_wbinstaller {{/str}}
                </button>
                <span class="text-muted align-self-center" data-region="filename"></span>
            </div>
        </div>
    </div>

    <div class="row mb-3" data-region="loader" hidden>
        <div class="col-12">
            <div class="alert alert-info mb-0">{{#str}} vuewaitingtext, tool_wbinstaller {{/str}}</div>
        </div>
    </div>

    <div class="row" data-region="status"></div>

    <div class="row mt-3" data-region="recipe-summary"></div>

    <div class="row mt-3" data-region="optional-plugins"></div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <strong>{{#str}} vueerrorheading, tool_wbinstaller {{/str}}</strong>
                </div>
                <div class="card-body">
                    <pre class="mb-0" data-region="feedback" style="white-space: pre-wrap;"></pre>
                </div>
            </div>
        </div>
    </div>
</div>
